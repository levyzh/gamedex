# Copy this file to `.env` and fill in real values. Vite only exposes vars that
# start with VITE_ to the browser. Restart `npm run dev` after any change here.

# RAWG API key — live game data (https://rawg.io/apidocs). Exposed in the browser.
VITE_RAWG_KEY=your_rawg_api_key_here

# Supabase project URL and public/anon (publishable) key. The anon key is safe
# to ship — RLS is the real protection, not secrecy.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Base URL of the Spring API. Dev is the local server; set the deployed API's
# URL in production.
VITE_API_URL=http://localhost:8080
